MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen3:4b
# For LM Studio, use Settings in the app or:
# MODEL_PROVIDER=lmstudio
# OLLAMA_BASE_URL=http://localhost:1234
NEURONOTES_DB_PATH=./data/neuronotes.db

# Security (local-first hardening)
# When set, every mutating request (POST/PUT) must send this token via
# `Authorization: Bearer <token>` or the `X-Neuronotes-Token` header.
# The desktop app generates and wires one automatically; for browser dev set
# the same value here AND as VITE_API_TOKEN in frontend/.env to enforce it.
# Leave unset for a frictionless browser dev loop (CORS still blocks websites).
# NEURONOTES_API_TOKEN=change-me-to-a-long-random-string
# Comma-separated origin allowlist. If unset, only localhost/127.0.0.1 (any
# port) and the Electron file:// renderer are allowed; external sites are blocked.
# NEURONOTES_ALLOWED_ORIGINS=http://localhost:5173
