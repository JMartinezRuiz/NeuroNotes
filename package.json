{
  "name": "neuronotes-2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ..\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8787",
    "dev:frontend": "npm --prefix frontend run dev",
    "desktop": "npm run build && electron electron/main.cjs",
    "build": "npm --prefix frontend run build",
    "mcp": "cd backend && ..\\.venv\\Scripts\\python -m app.mcp_server",
    "mcp:http": "cd backend && set \"NEURONOTES_MCP_TRANSPORT=sse\" && ..\\.venv\\Scripts\\python -m app.mcp_server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^39.2.7"
  }
}
